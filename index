<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Looké et Responsable - Cycle de vie d'un jean</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f9f9f9;
            color: #333;
        }
        h1 {
            color: #2c3e50;
            text-align: center;
        }
        h2 {
            color: #7f8c8d;
            text-align: center;
        }
        .game-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            max-width: 800px;
            margin: 0 auto;
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        .steps-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
            margin: 20px 0;
        }
        .step {
            background-color: #3498db;
            color: white;
            padding: 10px;
            border-radius: 5px;
            cursor: move;
            user-select: none;
            min-width: 120px;
            text-align: center;
        }
        .step:hover {
            background-color: #2980b9;
        }
        .drop-zone {
            background-color: #ecf0f1;
            border: 2px dashed #bdc3c7;
            border-radius: 5px;
            padding: 20px;
            min-height: 50px;
            width: 100%;
            margin: 20px 0;
            text-align: center;
        }
        .drop-zone.highlight {
            background-color: #d6eaf8;
            border-color: #3498db;
        }
        .hint {
            font-style: italic;
            color: #7f8c8d;
            text-align: center;
            margin: 10px 0;
        }
        button {
            background-color: #2ecc71;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
            margin: 10px;
        }
        button:hover {
            background-color: #27ae60;
        }
        .feedback {
            margin-top: 20px;
            padding: 10px;
            border-radius: 5px;
            text-align: center;
            font-weight: bold;
            display: none;
        }
        .correct {
            background-color: #d4edda;
            color: #155724;
        }
        .incorrect {
            background-color: #f8d7da;
            color: #721c24;
        }
    </style>
</head>
<body>
    <h1>Looké et Responsable</h1>
    <h2>Cycle de vie d'un jean</h2>
    <p>Remettez dans l'ordre les étapes de la vie d'un jean pour prendre conscience que toutes utilisent des ressources énergétiques.</p>
    <p class="hint">Indice : l'achat est la 18ème étape.</p>

    <div class="game-container">
        <div class="steps-container" id="steps-container">
            <!-- Les étapes seront insérées ici par JavaScript -->
        </div>

        <div class="drop-zone" id="drop-zone">
            Déposez les étapes ici dans le bon ordre
        </div>

        <button id="check-order">Vérifier l'ordre</button>
        <div class="feedback" id="feedback"></div>
    </div>

    <script>
        // Liste des étapes avec leur numéro
        const steps = [
            { id: 1, text: "Plantation du coton" },
            { id: 2, text: "Irrigation, utilisation d’engrais" },
            { id: 3, text: "Récoltes du coton" },
            { id: 4, text: "Transport du coton vers une usine" },
            { id: 5, text: "Nettoyage du coton" },
            { id: 6, text: "Séparation des fibres" },
            { id: 7, text: "Cadrage, filage, tissage, teinture" },
            { id: 8, text: "Fixation de la couleur (traitement chimique)" },
            { id: 9, text: "Séchage du tissu" },
            { id: 10, text: "Transport vers usines de confection" },
            { id: 11, text: "Découpage du tissu" },
            { id: 12, text: "Assemblage et couture" },
            { id: 13, text: "Pose des boutons, fermetures éclairs..." },
            { id: 14, text: "Contrôle qualité" },
            { id: 15, text: "Emballage" },
            { id: 16, text: "Transport vers un entrepôt" },
            { id: 17, text: "Transport vers un magasin" },
            { id: 18, text: "Achat" },
            { id: 19, text: "Port du vêtement" },
            { id: 20, text: "Lavage du vêtement (coût énergétique et eau)" },
            { id: 21, text: "On jette le Jeans dans une borne textile car trop usé" },
            { id: 22, text: "Transport vers centre de tri" },
            { id: 23, text: "Tri et découpage des pièces pour recycler" },
            { id: 24, text: "Recyclage ou seconde main" },
            { id: 25, text: "Stockage des déchets textiles" },
            { id: 26, text: "Incinération de matières non réutilisables" }
        ];

        // Mélanger les étapes pour le jeu
        const shuffledSteps = [...steps].sort(() => Math.random() - 0.5);

        // Afficher les étapes à trier
        const stepsContainer = document.getElementById('steps-container');
        shuffledSteps.forEach(step => {
            const stepElement = document.createElement('div');
            stepElement.className = 'step';
            stepElement.textContent = step.text;
            stepElement.draggable = true;
            stepElement.dataset.id = step.id;
            stepElement.addEventListener('dragstart', dragStart);
            stepsContainer.appendChild(stepElement);
        });

        // Zone de dépôt
        const dropZone = document.getElementById('drop-zone');
        dropZone.addEventListener('dragover', dragOver);
        dropZone.addEventListener('drop', drop);

        // Variables pour le drag and drop
        let draggedItem = null;

        function dragStart(e) {
            draggedItem = e.target;
            e.dataTransfer.setData('text/plain', e.target.dataset.id);
            setTimeout(() => {
                e.target.style.display = 'none';
            }, 0);
        }

        function dragOver(e) {
            e.preventDefault();
            dropZone.classList.add('highlight');
        }

        function drop(e) {
            e.preventDefault();
            dropZone.classList.remove('highlight');
            const id = e.dataTransfer.getData('text/plain');
            const draggedElement = document.querySelector(`.step[data-id="${id}"]`);
            dropZone.appendChild(draggedElement);
            draggedElement.style.display = 'block';
        }

        // Vérifier l'ordre
        document.getElementById('check-order').addEventListener('click', () => {
            const droppedSteps = Array.from(dropZone.children);
            let isCorrect = true;

            for (let i = 0; i < droppedSteps.length; i++) {
                if (parseInt(droppedSteps[i].dataset.id) !== i + 1) {
                    isCorrect = false;
                    break;
                }
            }

            const feedback = document.getElementById('feedback');
            if (isCorrect) {
                feedback.textContent = "Félicitations ! Vous avez mis toutes les étapes dans le bon ordre.";
                feedback.className = "feedback correct";
            } else {
                feedback.textContent = "Ce n'est pas encore le bon ordre. Essayez encore !";
                feedback.className = "feedback incorrect";
            }
            feedback.style.display = 'block';
        });
    </script>
</body>
</html>
